{
  "name": "neko-cafe-backend",
  "version": "0.1.0",
  "private": true,
  "description": "NekoCafe smart reservation backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
