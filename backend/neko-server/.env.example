# NekoCafe 正式后端（Spring Boot）环境变量示例。请勿提交真实密钥。
PORT=8080

# 数据源（JDBC）。Docker Compose 内主机名为 mysql；本地开发用 localhost。
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/neko_cafe?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8&useUnicode=true
SPRING_DATASOURCE_USERNAME=neko
SPRING_DATASOURCE_PASSWORD=neko

# Redis（短信验证码、热点门店缓存）
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# JWT 签名密钥（>=32 字节）。生产务必替换为随机强密钥并通过密钥管理注入。
NEKO_JWT_SECRET=neko-cafe-dev-secret-please-change-in-prod-0123456789abcdef
NEKO_JWT_TTL_SECONDS=86400

# 短信验证码沙箱固定码（演示用）
NEKO_SMS_FIXED_CODE=123456
NEKO_SMS_TTL_SECONDS=300
