SPRING_DATASOURCE_URL=jdbc:mysql://<rds-host>:3306/nekocafe?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=UTF-8&useUnicode=true
SPRING_DATASOURCE_USERNAME=<rds-user>
SPRING_DATASOURCE_PASSWORD=<rds-password>

# Docker Compose enables Flyway by default. Keep this true when using RDS.
SPRING_FLYWAY_ENABLED=true

# Keep true for an existing database that already has V001 tables but no Flyway history.
# After Flyway creates flyway_schema_history successfully, this can stay true or be removed.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
